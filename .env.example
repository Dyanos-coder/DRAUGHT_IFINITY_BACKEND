# Backend Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/
# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL (pour les redirections après paiement)
FRONTEND_URL=http://localhost:5173

# API URL (pour les callbacks)
API_URL=http://localhost:3000

# MoneyFusion (sera configuré via l'admin)
# La clé API et l'URL sont stockées dans la base de données via le modèle SiteConfig
# Pour initialiser : https://www.pay.moneyfusion.net/Pandora_Afrika/efa965e1a36b17b0/pay/

# Moneroo (ancien système de paiement)
MONEROO_API_KEY=your_moneroo_api_key_here
